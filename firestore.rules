rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /guesses/{id} {
      allow read, delete: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.contestant.name is string
        && request.resource.data.contestant.name.size() <= 50
        && request.resource.data.contestant.guess is string
        && request.resource.data.contestant.guess.size() <= 200
        && request.resource.data.showAnswer is bool
        && request.resource.data.dateSubmitted is timestamp;
    }

    match /guessVisibility/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /countdown/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
